# ═══════════════════════════════════════════════════
# MOZ VENDAS — Variáveis de Ambiente
# Copie para .env.local (dev) ou configure no Vercel
# ═══════════════════════════════════════════════════

# ── MongoDB Atlas ──────────────────────────────────
# Registe-se grátis em: https://cloud.mongodb.com
# Formato: mongodb+srv://USER:PASS@cluster.mongodb.net/mozvendas?retryWrites=true&w=majority
DATABASE_URL="mongodb+srv://UTILIZADOR:SENHA@cluster0.xxxxx.mongodb.net/mozvendas?retryWrites=true&w=majority"

# ── NextAuth.js ────────────────────────────────────
# Gere com: openssl rand -base64 32  (OBRIGATÓRIO!)
NEXTAUTH_SECRET="GERE_COM_openssl_rand_base64_32_AGORA"
NEXTAUTH_URL="https://SEU-DOMINIO.vercel.app"
# Em desenvolvimento: NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth (opcional) ────────────────────────
# Configure em: https://console.cloud.google.com
GOOGLE_CLIENT_ID="xxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxx"

# ── Cloudinary (upload de imagens) ─────────────────
# Registe-se grátis em: https://cloudinary.com
CLOUDINARY_CLOUD_NAME="o-seu-cloud-name"
CLOUDINARY_UPLOAD_PRESET="mozvendas_uploads"

# ── Admin Inicial ──────────────────────────────────
# Usado apenas uma vez para criar o primeiro admin
ADMIN_EMAIL="admin@mozvendas.co.mz"
ADMIN_PASSWORD="AdminForte@2026!"

# ── Protecção do Endpoint /api/seed ───────────────
# Qualquer string aleatória forte
SEED_SECRET="string-aleatoria-secreta-aqui"

# ── URL Base ───────────────────────────────────────
NEXT_PUBLIC_BASE_URL="https://SEU-DOMINIO.vercel.app"
